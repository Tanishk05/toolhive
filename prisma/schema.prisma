generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum AutopilotArea {
  tools
  ecosystem
  seo
  ux
  competitors
  revenue
  engineering
}

enum AutopilotRunStatus {
  started
  completed
  failed
  skipped
}

enum AutopilotRecommendationStatus {
  proposed
  issue_created
  pr_created
  accepted
  rejected
  shipped
}

model User {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  clerkId         String?          @unique
  email           String           @unique
  name            String?
  avatarUrl       String?
  role            String           @default("user")
  bio             String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  subscriptions    Subscription[]
  payments         Payment[]
  savedTools       SavedTool[]
  recentActivities RecentActivity[]
  analyticsEvents  AnalyticsEvent[]
  contactMessages  ContactMessage[]
  blogPosts        BlogPost[]
  auditLogs        AuditLog[]
  collections      Collection[]
  ratings          ToolRating[]
  startupKits      StartupKit[]
  reverseAnalyses  ReverseAnalysis[]
}

model SavedTool {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  toolSlug  String
  createdAt DateTime @default(now())

  @@unique([userId, toolSlug])
}

model RecentActivity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  toolSlug  String
  visitedAt DateTime @default(now())

  @@index([userId, visitedAt])
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug           String   @unique
  label          String
  description    String
  seoTitle       String?
  seoDescription String?
  seoCanonical   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tools          Tool[]
  blogPosts      BlogPost[]
}

model Tool {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  slug           String   @unique
  name           String
  summary        String
  description    String
  icon           String?
  url            String?
  featured       Boolean  @default(false)
  published      Boolean  @default(false)
  premium        Boolean  @default(false)
  popularity     Int      @default(0)
  accent         String?
  tags           String[] @default([])
  searchTerms    String[] @default([])
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[] @default([])
  seoCanonical   String?
  categoryId     String   @db.ObjectId
  category       Category @relation(fields: [categoryId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BlogPost {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  slug       String    @unique
  title          String
  excerpt        String
  content        String
  coverImage     String?
  published      Boolean   @default(false)
  featured       Boolean   @default(false)
  tags           String[]  @default([])
  seoTitle       String?
  seoDescription String?
  categoryId String?   @db.ObjectId
  category   Category? @relation(fields: [categoryId], references: [id])
  authorId   String?   @db.ObjectId
  author     User?     @relation(fields: [authorId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Subscription {
  id              String             @id @default(auto()) @map("_id") @db.ObjectId
  userId          String             @db.ObjectId
  user            User               @relation(fields: [userId], references: [id])
  provider        String
  providerPlanId  String
  status          SubscriptionStatus @default(trialing)
  currentPeriodAt DateTime?
  endsAt          DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Payment {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  userId      String        @db.ObjectId
  user        User          @relation(fields: [userId], references: [id])
  provider    String
  providerRef String?
  amount      Int
  currency    String
  status      PaymentStatus @default(pending)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  source    String?
  payload   Json?
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  email     String
  subject   String
  message   String
  category  String?
  priority  String?
  type      String   @default("contact")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  subscribedAt DateTime @default(now())
  unsubscribed Boolean  @default(false)
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  action     String
  resource   String
  resourceId String?
  userId     String?  @db.ObjectId
  user       User?    @relation(fields: [userId], references: [id])
  metadata   Json?
  createdAt  DateTime @default(now())
}

model FeatureFlag {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Collection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  name        String
  slug        String   @unique
  description String?
  coverImage  String?
  isPublic    Boolean  @default(false)
  isEditorPick Boolean @default(false)
  tools       String[]
  
  views       Int      @default(0)
  likesCount  Int      @default(0)
  bookmarksCount Int   @default(0)
  
  likedBy     String[] @default([]) // Array of User IDs
  bookmarkedBy String[] @default([]) // Array of User IDs
  followers   String[] @default([]) // Array of User IDs
  collaborators String[] @default([]) // Array of User IDs
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model ToolRating {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  toolSlug  String
  rating    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, toolSlug])
  @@index([toolSlug])
}

model Toolkit {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  description String
  workflow    String?
  tips        String?
  tools       String[]
  creatorId   String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StartupKit {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId
  user        User?    @relation(fields: [userId], references: [id])
  idea        String
  name        String
  content     Json
  isPublic    Boolean  @default(false)
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReverseAnalysis {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?  @db.ObjectId
  user        User?    @relation(fields: [userId], references: [id])
  targetUrl   String?
  targetImage String?  // URL to stored image or just metadata
  content     Json
  isPublic    Boolean  @default(false)
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AutopilotRun {
  id             String             @id @default(auto()) @map("_id") @db.ObjectId
  area           AutopilotArea
  status         AutopilotRunStatus @default(started)
  source         String
  summary        String?
  githubIssueUrl String?
  githubPrUrl    String?
  input          Json?
  output         Json?
  error          String?
  startedAt      DateTime           @default(now())
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([area, createdAt])
  @@index([status, createdAt])
}

model AutopilotRecommendation {
  id             String                         @id @default(auto()) @map("_id") @db.ObjectId
  area           AutopilotArea
  title          String
  summary        String
  impact         String
  effort         String
  technicalRisk  String
  businessValue  String
  priority       Int
  status         AutopilotRecommendationStatus @default(proposed)
  sourceUrls     String[]                       @default([])
  targetPaths    String[]                       @default([])
  githubIssueUrl String?
  githubPrUrl    String?
  metadata       Json?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt

  @@index([area, priority, createdAt])
  @@index([status, createdAt])
}
